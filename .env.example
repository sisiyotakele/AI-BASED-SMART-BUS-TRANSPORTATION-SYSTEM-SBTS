# ================================================================
# Database
# ================================================================
DATABASE_URL="postgresql://username:password@localhost:5432/smart_bus_db"

# ================================================================
# Environment
# ================================================================
NODE_ENV=development

# ================================================================
# Backend
# ================================================================
BACKEND_PORT=4000

# ================================================================
# Authentication
# ================================================================
JWT_SECRET="your-super-secret-jwt-key"

# ================================================================
# AI Service
# ================================================================
AI_SERVICE_URL=http://localhost:8000

# ================================================================
# Frontend
# ================================================================
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000

# ================================================================
# Seed Configuration
# ================================================================
ADMIN_NAME="System Administrator"
ADMIN_EMAIL="admin@example.com"
ADMIN_PHONE="+251900000001"

ADMIN_PASSWORD="ChangeMe_Before_Use"
SEED_DEFAULT_PASSWORD="ChangeMe_Default"

SEED_PHONE_PREFIX="+251911"

SEED_DRIVERS_COUNT=15
SEED_PASSENGERS_COUNT=30
SEED_BUSES_COUNT=25

SEED_SAMPLE_DATA=true

# Uncomment only when you intentionally want destructive seeding
# SEED_CONFIRM_DESTRUCTIVE=yes